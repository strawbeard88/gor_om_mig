{
  "name": "tlab-redesign",
  "version": "1.0.0",
  "description": "Redesign av TLAB:s startsida",
  "scripts": {
    "build": "sass src/scss/main.scss dist/css/main.css --style compressed --no-source-map",
    "build:dev": "sass src/scss/main.scss dist/css/main.css --style expanded",
    "watch": "sass src/scss/main.scss dist/css/main.css --watch --style expanded"
  },
  "dependencies": {
    "sass": "^1.99.0",
    "scss": "^0.2.4"
  }
}
